<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="nav-links">
            <a href="/" class="btn btn-outline nav-btn">&larr; Back to Library</a>
        </div>
    </nav>

    <main class="container">
        <div class="manage-grid animate-fade-in">
            <!-- Left Side: Basic Info -->
            <div class="manage-card">
                <h2>Concept Details</h2>
                <form action="/concept/<%= concept._id %>/update" method="POST">
                    <div class="form-group">
                        <label for="title">Title</label>
                        <input type="text" id="title" name="title" value="<%= concept.title %>" required>
                    </div>

                    <div class="form-group">
                        <label for="subject-select">Subject / Category</label>
                        <select id="subject-select" onchange="toggleSubjectInput(this.value)">
                            <% allSubjects.forEach(s => { %>
                                <option value="<%= s %>" <%= concept.subject === s ? 'selected' : '' %>><%= s %></option>
                            <% }) %>
                            <option value="new" style="font-weight: 800; color: var(--accent-primary);">+ Add New Subject</option>
                        </select>

                        <div id="new-subject-container" style="display: none; margin-top: 1rem;">
                            <input type="text" id="subject-new" placeholder="Enter new subject name">
                        </div>

                        <input type="hidden" name="subject" id="subject-final" value="<%= concept.subject %>" required>
                    </div>

                    <div class="form-group">
                        <label for="sortOrder">Sort Order</label>
                        <input type="number" id="sortOrder" name="sortOrder" value="<%= concept.sortOrder %>">
                    </div>

                    <div class="form-group">
                        <label for="parentId">Parent Concept</label>
                        <select id="parentId" name="parentId">
                            <option value="">-- No Parent --</option>
                            <% allConcepts.forEach(c => { %>
                                <% if (c._id.toString() != concept._id.toString()) { %>
                                    <option value="<%= c._id %>" <%= concept.parentId && concept.parentId.toString() == c._id.toString() ? 'selected' : '' %>>
                                        <%= c.subject %>: <%= c.title %>
                                    </option>
                                <% } %>
                            <% }) %>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Save Changes</button>
                </form>

                <div class="danger-zone" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(255, 255, 255, 0.05);">
                    <form action="/concept/<%= concept._id %>/delete" method="POST" onsubmit="return confirm('Are you sure? This cannot be undone.')">
                        <button type="submit" class="btn" style="width: 100%; justify-content: center; background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 1px solid rgba(244, 63, 94, 0.2);">
                            Delete Concept
                        </button>
                    </form>
                </div>
            </div>

            <!-- Right Side: Content Actions -->
            <div class="manage-card">
                <h2>Content Management</h2>
                
                <div style="margin-bottom: 2.5rem;">
                    <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Directly modify the HTML source code using the high-performance Monaco Editor.</p>
                    <a href="/concept/<%= concept._id %>/edit" class="btn btn-primary" style="width: 100%; justify-content: center; background: #10b981;">
                        Open Visual Editor 📝
                    </a>
                </div>

                <div style="padding-top: 2.5rem; border-top: 1px solid var(--glass-border);">
                    <h3>Replace Source File</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.9rem;">Current file: <code><%= concept.originalName %></code></p>
                    
                    <form action="/concept/<%= concept._id %>/replace" method="POST" enctype="multipart/form-data">
                        <div class="form-group">
                            <input type="file" id="conceptFile" name="conceptFile" accept=".html" required onchange="updateFileName()">
                        </div>
                        <button type="submit" class="btn btn-outline" style="width: 100%; justify-content: center;">Upload & Replace</button>
                    </form>
                </div>

                <div style="margin-top: 2.5rem; padding: 1.5rem; background: rgba(99, 102, 241, 0.05); border-radius: 16px; border: 1px dashed rgba(99, 102, 241, 0.2);">
                    <h4 style="margin-bottom: 0.5rem; color: var(--accent-primary);">Public URL</h4>
                    <p style="font-size: 0.85rem; word-break: break-all; opacity: 0.7;">https://nimcet.erpsaas.in/view/<%= concept._id %></p>
                </div>
            </div>
        </div>
    </main>

    <script>
        function toggleSubjectInput(val) {
            const container = document.getElementById('new-subject-container');
            const finalInput = document.getElementById('subject-final');
            const newInput = document.getElementById('subject-new');
            
            if (val === 'new') {
                container.style.display = 'block';
                newInput.focus();
                
                newInput.oninput = () => {
                    finalInput.value = newInput.value;
                };
            } else {
                container.style.display = 'none';
                finalInput.value = val;
                newInput.oninput = null;
            }
        }
        
        // Initial sync
        toggleSubjectInput(document.getElementById('subject-select').value);

        function updateFileName() {
            // Placeholder for filename update logic if needed
        }
    </script>
</body>
</html>
