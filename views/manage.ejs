<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="nav-links">
            <a href="/" class="btn btn-outline nav-btn">&larr; Back to Library</a>
        </div>
    </nav>

    <main class="container">
        <div class="manage-grid animate-fade-in">
            <!-- Details & Update -->
            <div class="manage-card">
                <h2>Concept Details</h2>
                <form action="/concept/<%= concept.id %>/update" method="POST">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="title">Title</label>
                            <input type="text" id="title" name="title" value="<%= concept.title %>" required>
                        </div>
                        <div class="form-group">
                            <label for="subject-select">Subject</label>
                            <select id="subject-select" onchange="toggleSubjectInput(this.value)">
                                <% allSubjects.forEach(s => { %>
                                    <option value="<%= s %>" <%= concept.subject === s ? 'selected' : '' %>><%= s %></option>
                                <% }) %>
                                <option value="new" style="font-weight: 800; color: var(--accent-primary);">+ Add New Subject</option>
                            </select>

                            <div id="new-subject-container" style="display: none; margin-top: 1rem;">
                                <input type="text" id="subject-new" placeholder="Enter new subject name">
                            </div>

                            <input type="hidden" name="subject" id="subject-final" value="<%= concept.subject %>" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="sortOrder">Sort Order</label>
                            <input type="number" id="sortOrder" name="sortOrder" value="<%= concept.sortOrder || 0 %>">
                        </div>
                        <div class="form-group">
                            <label for="parentId">Parent Concept</label>
                            <select id="parentId" name="parentId">
                                <option value="">-- No Parent --</option>
                                <% allConcepts.forEach(c => { %>
                                    <% if (c.id != concept.id) { %>
                                        <option value="<%= c.id %>" <%= concept.parentId == c.id ? 'selected' : '' %>>
                                            <%= c.subject %>: <%= c.title %>
                                        </option>
                                    <% } %>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Save Changes</button>
                </form>

                <div class="danger-zone">
                    <p style="color: #ef4444; font-size: 0.9rem; margin-bottom: 1rem;">Delete this concept permanently.</p>
                    <form action="/concept/<%= concept.id %>/delete" method="POST" onsubmit="return confirm('Are you sure? This cannot be undone.')">
                        <button type="submit" class="btn btn-danger" style="width: 100%; justify-content: center;">Delete Concept</button>
                    </form>
                </div>
            </div>

            <!-- Content Management -->
            <div class="manage-card">
                <h2>Content Actions</h2>
                
                <div style="margin-bottom: 2rem;">
                    <p style="color: var(--text-secondary); margin-bottom: 1rem;">Directly edit the HTML code using our built-in VS Code-style editor.</p>
                    <a href="/concept/<%= concept.id %>/edit" class="btn btn-primary" style="width: 100%; justify-content: center; background: #22c55e;">
                        Open Code Editor 📝
                    </a>
                </div>

                <div style="padding-top: 2rem; border-top: 1px solid var(--glass-border);">
                    <h3>Replace Source File</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.9rem;">Current: <%= concept.originalName %></p>
                    <form action="/concept/<%= concept.id %>/replace" method="POST" enctype="multipart/form-data">
                        <div class="form-group">
                            <div class="file-input-wrapper" style="padding: 1rem;">
                                <p id="file-name-display" style="font-size: 0.8rem;">Click to select new file</p>
                                <input type="file" id="conceptFile" name="conceptFile" accept=".html" required onchange="updateFileName()">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-outline" style="width: 100%; justify-content: center;">Upload & Replace</button>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <script>
        function toggleSubjectInput(val) {
            const container = document.getElementById('new-subject-container');
            const finalInput = document.getElementById('subject-final');
            const newInput = document.getElementById('subject-new');
            
            if (val === 'new') {
                container.style.display = 'block';
                newInput.focus();
                
                newInput.oninput = () => {
                    finalInput.value = newInput.value;
                };
            } else {
                container.style.display = 'none';
                finalInput.value = val;
                newInput.oninput = null;
            }
        }
        
        // Initial sync
        toggleSubjectInput(document.getElementById('subject-select').value);

        function updateFileName() {
            const input = document.getElementById('conceptFile');
            const display = document.getElementById('file-name-display');
            if (input.files.length > 0) {
                display.innerText = "Selected: " + input.files[0].name;
            }
        }
    </script>
</body>
</html>
