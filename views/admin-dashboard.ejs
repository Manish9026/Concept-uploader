<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <style>
        .file-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .file-card {
            background: var(--bg-secondary);
            border: 1px solid var(--glass-border);
            padding: 1.5rem;
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .file-status {
            font-size: 0.75rem;
            padding: 0.2rem 0.6rem;
            border-radius: 100px;
            width: fit-content;
        }
        .status-tracked { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
        .status-orphan { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Admin Console</a>
        <div class="nav-links">
            <a href="/upload" class="btn btn-outline nav-btn">Direct Upload</a>
            <a href="/admin/logout" class="btn btn-danger nav-btn" style="padding: 0.5rem 1rem;">Logout</a>
        </div>
    </nav>

    <main class="container">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h1 style="font-size: 2.5rem; margin: 0;">Uploads Directory</h1>
                <p style="color: var(--text-secondary);">Direct file system management for the <code>/uploads</code> folder.</p>
            </div>
            <div style="color: var(--text-secondary); font-size: 0.9rem;">
                Total Files: <%= files.length %>
            </div>
        </div>

        <div class="file-grid animate-fade-in">
            <% files.forEach(file => { %>
                <div class="file-card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <span class="file-status <%= file.isTracked ? 'status-tracked' : 'status-orphan' %>">
                            <%= file.isTracked ? 'Linked to Concept' : 'Orphaned (No metadata)' %>
                        </span>
                        <code style="font-size: 0.7rem; opacity: 0.5;"><%= (file.stats.size / 1024).toFixed(2) %> KB</code>
                    </div>
                    
                    <div>
                        <h3 style="font-size: 1.1rem; margin-bottom: 0.2rem; word-break: break-all;"><%= file.name %></h3>
                        <p style="font-size: 0.85rem; color: var(--accent-primary);"><%= file.conceptTitle %></p>
                    </div>

                    <div style="display: flex; gap: 0.5rem; margin-top: auto;">
                        <a href="/uploads/<%= file.name %>" target="_blank" class="btn btn-outline" style="flex: 1; justify-content: center; padding: 0.5rem; font-size: 0.8rem;">Open File</a>
                        <form action="/admin/delete-file" method="POST" style="flex: 1;" onsubmit="return confirm('Delete this file permanently? Metadata will also be removed.')">
                            <input type="hidden" name="filename" value="<%= file.name %>">
                            <button type="submit" class="btn btn-danger" style="width: 100%; justify-content: center; padding: 0.5rem; font-size: 0.8rem;">Delete</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>

        <% if (files.length === 0) { %>
            <div class="empty-state" style="margin-top: 4rem;">
                <h2>Uploads folder is empty</h2>
                <p>Files will appear here once they are uploaded or pasted.</p>
            </div>
        <% } %>
    </main>
</body>
</html>
