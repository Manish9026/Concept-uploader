<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="nav-links">
            <a href="/" class="btn btn-outline nav-btn">&larr; Back</a>
        </div>
    </nav>

    <main class="container">
        <div class="manage-card animate-fade-in" style="max-width: 800px; margin: 2rem auto;">
            <h1 style="font-size: 2.5rem; margin-bottom: 2rem;">Contribute Concept</h1>
            
            <form action="/upload" method="POST" enctype="multipart/form-data">
                <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                    <div class="form-group">
                        <label for="title">Concept Title</label>
                        <input type="text" id="title" name="title" placeholder="e.g. Memory Management" required>
                    </div>
                    <div class="form-group">
                        <label for="subject-select">Subject / Category</label>
                        <select id="subject-select" onchange="toggleSubjectInput(this.value)">
                            <option value="">-- Select Subject --</option>
                            <% allSubjects.forEach(s => { %>
                                <option value="<%= s %>"><%= s %></option>
                            <% }) %>
                            <option value="new" style="font-weight: 800; color: var(--accent-primary);">+ Add New Subject</option>
                        </select>
                        
                        <div id="new-subject-container" style="display: none; margin-top: 1rem;">
                            <input type="text" id="subject-new" placeholder="Enter new subject name">
                        </div>

                        <input type="hidden" name="subject" id="subject-final" required>
                    </div>
                </div>

                <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2.5rem;">
                    <div class="form-group">
                        <label for="sortOrder">Sort Order</label>
                        <input type="number" id="sortOrder" name="sortOrder" placeholder="0" value="0">
                        <p class="input-hint" style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.5rem;">Lower numbers appear first.</p>
                    </div>
                    <div class="form-group">
                        <label for="parentId">Parent Concept (Optional)</label>
                        <select id="parentId" name="parentId">
                            <option value="">-- No Parent --</option>
                            <% allConcepts.forEach(c => { %>
                                <option value="<%= c._id %>"><%= c.subject %>: <%= c.title %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="tabs" style="display: flex; gap: 2rem; margin-bottom: 2rem; border-bottom: 1px solid var(--glass-border);">
                    <div class="tab active" onclick="switchTab('upload-tab', this)" style="padding: 1rem 0; cursor: pointer; border-bottom: 2px solid var(--accent-primary);">Upload File</div>
                    <div class="tab" onclick="switchTab('paste-tab', this)" style="padding: 1rem 0; cursor: pointer; color: var(--text-secondary);">Paste HTML</div>
                </div>

                <div id="upload-tab" class="tab-content">
                    <div class="form-group">
                        <label>HTML File Source</label>
                        <input type="file" id="conceptFile" name="conceptFile" accept=".html">
                    </div>
                </div>

                <div id="paste-tab" class="tab-content" style="display: none;">
                    <div class="form-group">
                        <label for="pasteContent">Paste HTML Code</label>
                        <textarea id="pasteContent" name="pasteContent" style="height: 300px; font-family: monospace;" placeholder="<html>...</html>"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 2rem; padding: 1.2rem;">
                    Launch Concept 🚀
                </button>
            </form>
        </div>
    </main>

    <script>
        function switchTab(tabId, el) {
            document.querySelectorAll('.tab').forEach(t => {
                t.classList.remove('active');
                t.style.color = 'var(--text-secondary)';
                t.style.borderBottomColor = 'transparent';
            });
            document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
            
            el.classList.add('active');
            el.style.color = 'var(--text-primary)';
            el.style.borderBottomColor = 'var(--accent-primary)';
            document.getElementById(tabId).style.display = 'block';
            
            const fileInput = document.getElementById('conceptFile');
            const pasteArea = document.getElementById('pasteContent');
            if (tabId === 'upload-tab') {
                fileInput.required = true;
                pasteArea.required = false;
            } else {
                fileInput.required = false;
                pasteArea.required = true;
            }
        }
        
        switchTab('upload-tab', document.querySelector('.tab'));

        function toggleSubjectInput(val) {
            const container = document.getElementById('new-subject-container');
            const finalInput = document.getElementById('subject-final');
            const newInput = document.getElementById('subject-new');
            
            if (val === 'new') {
                container.style.display = 'block';
                newInput.focus();
                newInput.oninput = () => { finalInput.value = newInput.value; };
            } else {
                container.style.display = 'none';
                finalInput.value = val;
            }
        }
    </script>
</body>
</html>
