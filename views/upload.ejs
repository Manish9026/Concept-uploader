<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="nav-links">
            <a href="/" class="btn btn-outline nav-btn">&larr; Back</a>
        </div>
    </nav>

    <main class="container">
        <div class="form-container animate-fade-in" style="max-width: 800px;">
            <form action="/upload" method="POST" enctype="multipart/form-data">
                <div class="form-row">
                    <div class="form-group">
                        <label for="title">Concept Title</label>
                        <input type="text" id="title" name="title" placeholder="e.g. Memory Management" required>
                    </div>
                    <div class="form-group">
                        <label for="subject-select">Subject / Category</label>
                        <select id="subject-select" onchange="toggleSubjectInput(this.value)">
                            <option value="">-- Select Subject --</option>
                            <% allSubjects.forEach(s => { %>
                                <option value="<%= s %>"><%= s %></option>
                            <% }) %>
                            <option value="new" style="font-weight: 800; color: var(--accent-primary);">+ Add New Subject</option>
                        </select>
                        
                        <!-- Hidden by default, shown if "new" is selected -->
                        <div id="new-subject-container" style="display: none; margin-top: 1rem;">
                            <input type="text" id="subject-new" placeholder="Enter new subject name">
                            <p class="input-hint">This will be saved for future use.</p>
                        </div>

                        <!-- The actual field sent to the server -->
                        <input type="hidden" name="subject" id="subject-final" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="sortOrder">Sort Order</label>
                        <input type="number" id="sortOrder" name="sortOrder" placeholder="0" value="0">
                        <p class="input-hint">Lower numbers appear first.</p>
                    </div>
                    <div class="form-group">
                        <label for="parentId">Parent Concept (Optional)</label>
                        <select id="parentId" name="parentId">
                            <option value="">-- No Parent --</option>
                            <% allConcepts.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.subject %>: <%= c.title %></option>
                            <% }) %>
                        </select>
                        <p class="input-hint">Nest this concept under another.</p>
                    </div>
                </div>

                <div class="tabs">
                    <div class="tab active" onclick="switchTab('upload-tab', this)">Upload File</div>
                    <div class="tab" onclick="switchTab('paste-tab', this)">Paste HTML</div>
                </div>

                <div id="upload-tab" class="tab-content active">
                    <div class="form-group">
                        <label>HTML File</label>
                        <div class="file-input-wrapper">
                            <p id="file-name-display">Click to select or drag & drop .html file</p>
                            <input type="file" id="conceptFile" name="conceptFile" accept=".html">
                        </div>
                    </div>
                </div>

                <div id="paste-tab" class="tab-content">
                    <div class="form-group">
                        <label for="pasteContent">Paste HTML Code</label>
                        <textarea id="pasteContent" name="pasteContent" class="paste-area" placeholder="<html>...</html>"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 1rem;">
                    Create Concept
                </button>
            </form>
        </div>
    </main>

    <script>
        function switchTab(tabId, el) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            el.classList.add('active');
            document.getElementById(tabId).classList.add('active');
            
            // Toggle required attributes
            const fileInput = document.getElementById('conceptFile');
            const pasteArea = document.getElementById('pasteContent');
            if (tabId === 'upload-tab') {
                fileInput.required = true;
                pasteArea.required = false;
            } else {
                fileInput.required = false;
                pasteArea.required = true;
            }
        }
        
        // Initialize
        switchTab('upload-tab', document.querySelector('.tab'));

        function toggleSubjectInput(val) {
            const container = document.getElementById('new-subject-container');
            const finalInput = document.getElementById('subject-final');
            const newInput = document.getElementById('subject-new');
            
            if (val === 'new') {
                container.style.display = 'block';
                finalInput.value = ''; // Clear so validation catches it if empty
                newInput.focus();
                
                newInput.oninput = () => {
                    finalInput.value = newInput.value;
                };
            } else {
                container.style.display = 'none';
                finalInput.value = val;
                newInput.oninput = null;
            }
        }
        
        // Initial sync
        toggleSubjectInput(document.getElementById('subject-select').value);

        function updateFileName() {
            const input = document.getElementById('conceptFile');
            const display = document.getElementById('file-name-display');
            if (input.files.length > 0) {
                display.innerText = "Selected: " + input.files[0].name;
                display.style.color = "var(--accent-primary)";
            }
        }
    </script>
</body>
</html>
