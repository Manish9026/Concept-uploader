<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editing: <%= concept.title %> | Concept Vault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <!-- Monaco MUST load before Lucide to avoid AMD require conflict -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>

    <style>
        html, body { height: 100%; margin: 0; overflow: hidden; background: #1e1e1e; }
        .editor-bar {
            display: flex; justify-content: space-between; align-items: center;
            height: 44px; padding: 0 1rem;
            background: #252526; border-bottom: 1px solid #3c3c3c;
            font-family: 'Outfit', sans-serif;
        }
        .editor-bar-left { display: flex; align-items: center; gap: 0.8rem; }
        .editor-bar-right { display: flex; align-items: center; gap: 0.8rem; }
        .back-btn {
            padding: 0.25rem 0.7rem; border-radius: 4px; font-size: 0.8rem;
            background: transparent; border: 1px solid #555;
            color: #ccc; text-decoration: none; transition: 0.15s;
        }
        .back-btn:hover { background: #3c3c3c; color: #fff; }
        .file-name { font-size: 0.85rem; font-weight: 600; color: #e0e0e0; }
        .file-ext {
            font-size: 0.65rem; padding: 0.1rem 0.35rem; border-radius: 3px;
            background: #264f78; color: #9cdcfe; font-family: monospace;
        }
        .dot-sep { color: #555; font-size: 0.6rem; }
        #save-status { font-size: 0.75rem; color: #888; }
        .save-btn {
            padding: 0.25rem 0.9rem; border-radius: 4px; border: none; cursor: pointer;
            font-size: 0.8rem; font-weight: 600; color: #fff;
            background: #0e639c; transition: 0.15s;
        }
        .save-btn:hover { background: #1177bb; }
        #monaco-container { width: 100%; height: calc(100vh - 44px); }
    </style>
</head>
<body>
    <div class="editor-bar">
        <div class="editor-bar-left">
            <a href="/concept/<%= concept._id %>" class="back-btn">← Exit</a>
            <span class="dot-sep">|</span>
            <span class="file-name"><%= concept.title %></span>
            <span class="file-ext"><%= concept.originalName %></span>
        </div>
        <div class="editor-bar-right">
            <span id="save-status"></span>
            <button class="save-btn" onclick="saveContent()">💾 Save</button>
        </div>
    </div>

    <div id="monaco-container"></div>

    <textarea id="raw-content" style="display:none;"><%= content %></textarea>

    <script>
        let editor, originalContent = '', isDirty = false;

        require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' } });

        require(['vs/editor/editor.main'], function() {
            originalContent = document.getElementById('raw-content').value;
            editor = monaco.editor.create(document.getElementById('monaco-container'), {
                value: originalContent,
                language: 'html',
                theme: 'vs-dark',
                automaticLayout: true,
                fontSize: 14,
                minimap: { enabled: true },
                padding: { top: 12 },
                scrollBeyondLastLine: false,
                wordWrap: 'on',
                bracketPairColorization: { enabled: true },
                renderLineHighlight: 'line',
                cursorBlinking: 'smooth',
                smoothScrolling: true,
                mouseWheelZoom: true
            });

            editor.onDidChangeModelContent(() => {
                isDirty = editor.getValue() !== originalContent;
            });

            editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS, () => saveContent());
        });

        window.addEventListener('beforeunload', (e) => {
            if (isDirty) { e.preventDefault(); e.returnValue = ''; }
        });

        async function saveContent() {
            const status = document.getElementById('save-status');
            status.textContent = 'Saving…'; status.style.color = '#888';
            try {
                const res = await fetch('/concept/<%= concept._id %>/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: editor.getValue() })
                });
                if (res.ok) {
                    originalContent = editor.getValue(); isDirty = false;
                    status.textContent = '✓ Saved ' + new Date().toLocaleTimeString();
                    status.style.color = '#4ec9b0';
                } else {
                    const d = await res.json(); throw new Error(d.error || 'Failed');
                }
            } catch (err) {
                status.textContent = '✗ ' + err.message; status.style.color = '#f14c4c';
            }
        }
    </script>
</body>
</html>
