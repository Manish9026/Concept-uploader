<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <!-- Monaco Editor Loader -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>
</head>
<body class="editor-page-body">
    <div class="editor-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/concept/<%= concept._id %>" class="btn btn-outline" style="padding: 0.5rem 1rem;">&larr; Exit</a>
            <h2 style="font-size: 1.2rem; margin: 0;"><%= concept.title %> <span style="color: var(--text-secondary); font-weight: 400; font-size: 0.9rem;">(<%= concept.originalName %>)</span></h2>
        </div>
        <div style="display: flex; gap: 1rem;">
            <span id="save-status" style="color: var(--text-secondary); font-size: 0.9rem; align-self: center; margin-right: 1rem;"></span>
            <button onclick="saveContent()" class="btn btn-primary" style="padding: 0.5rem 2rem;">Save File</button>
        </div>
    </div>

    <div class="editor-container">
        <div id="monaco-container"></div>
    </div>

    <!-- Hidden element to safely store content -->
    <textarea id="raw-content" style="display: none;"><%= content %></textarea>

    <script>
        let editor;
        require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' } });
        
        let originalContent = '';
        let isDirty = false;

        require(['vs/editor/editor.main'], function() {
            originalContent = document.getElementById('raw-content').value;
            editor = monaco.editor.create(document.getElementById('monaco-container'), {
                value: originalContent,
                language: 'html',
                theme: 'vs-dark',
                automaticLayout: true,
                fontSize: 14,
                minimap: { enabled: true },
                padding: { top: 20 }
            });

            // Detect changes
            editor.onDidChangeModelContent(() => {
                isDirty = editor.getValue() !== originalContent;
            });

            // Keyboard shortcut for saving (Ctrl+S / Cmd+S)
            editor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS, function() {
                saveContent();
            });
        });

        // Warn before leaving with unsaved changes
        window.addEventListener('beforeunload', (e) => {
            if (isDirty) {
                e.preventDefault();
                e.returnValue = ''; // Trigger browser confirmation dialog
            }
        });

        async function saveContent() {
            const status = document.getElementById('save-status');
            status.innerText = 'Saving...';
            
            const content = editor.getValue();
            try {
                const response = await fetch('/concept/<%= concept._id %>/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content })
                });
                
                if (response.ok) {
                    status.innerText = 'Last saved: ' + new Date().toLocaleTimeString();
                    status.style.color = '#22c55e';
                    originalContent = content; // Update original content to current
                    isDirty = false;
                } else {
                    const errorData = await response.json();
                    throw new Error(errorData.error || 'Save failed');
                }
            } catch (err) {
                console.error('Save error:', err);
                status.innerText = 'Error: ' + err.message;
                status.style.color = '#ef4444';
            }
        }
    </script>
</body>
</html>
