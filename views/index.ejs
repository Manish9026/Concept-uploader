<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="menu-toggle" onclick="toggleMenu()">
            <span></span><span></span><span></span>
        </div>
        <div class="nav-overlay" id="navOverlay" onclick="toggleMenu()"></div>
        <div class="nav-links" id="navLinks">
            <div class="mobile-close-btn" onclick="toggleMenu()">
                <i data-lucide="x"></i>
            </div>
            <div class="controls-bar" style="display:flex;gap:0.5rem;">
                <select id="subject-filter" class="sort-select" onchange="filterBySubject(this.value)">
                    <option value="all">All Subjects</option>
                    <% allSubjects.forEach(s => { %>
                        <option value="<%= s %>"><%= s %></option>
                    <% }) %>
                </select>
                <select id="sort" class="sort-select" onchange="window.location.href='/?sort='+this.value">
                    <option value="order-asc" <%= sortBy === 'order-asc' ? 'selected' : '' %>>Sort Order</option>
                    <option value="date-desc" <%= sortBy === 'date-desc' ? 'selected' : '' %>>Latest First</option>
                    <option value="title-asc" <%= sortBy === 'title-asc' ? 'selected' : '' %>>Title A-Z</option>
                </select>
            </div>
            <a href="/upload" class="btn btn-primary nav-btn">New Concept +</a>
            <% if (isAuthenticated) { %>
                <a href="/auth/logout" class="btn btn-outline nav-btn" title="Logout"><i data-lucide="log-out"></i></a>
            <% } %>
        </div>
    </nav>

    <main class="container">
        <% if (Object.keys(subjects).length === 0) { %>
            <div class="empty-state animate-fade-in">
                <h2>No concepts yet</h2>
                <p>Upload your first HTML concept file to get started.</p>
                <br>
                <a href="/upload" class="btn btn-outline">Go to Upload</a>
            </div>
        <% } else { %>
            <% for (let subject in subjects) { %>
                <section class="subject-section animate-fade-in" data-subject="<%= subject %>">
                    <h2 class="subject-title"><%= subject %></h2>
                    <div class="tree-list">
<%
    function renderNode(concept, allInSubject, depth) {
        const children = allInSubject.filter(c => c.parentId && c.parentId.toString() === concept._id.toString());
        const hasChildren = children.length > 0;
%>
                        <div class="tree-row depth-<%= depth %>">
                            <div class="tree-rail"><div class="tree-dot"></div></div>
                            <div class="tree-arm"></div>
                            <div class="tree-card">
                                <div class="card-header">
                                    <% if (hasChildren) { %>
                                        <div class="toggle-btn open" onclick="toggleNode(this, '<%= concept._id %>')">
                                            <i data-lucide="chevron-right"></i>
                                        </div>
                                    <% } else { %>
                                        <div class="toggle-spacer"></div>
                                    <% } %>
                                    <div style="flex:1;min-width:0;">
                                        <div class="card-title"><%= concept.title %></div>
                                        <div class="card-meta">
                                            <span><i data-lucide="calendar"></i> <%= new Date(concept.uploadDate).toLocaleDateString() %></span>
                                            <% if (concept.sortOrder) { %>
                                                <span><i data-lucide="hash"></i> <%= concept.sortOrder %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="card-actions">
                                        <% if (concept.media && concept.media.fileName) { %>
                                            <a href="/concept/<%= concept._id %>/media/viewer" target="_blank" class="btn-icon" title="View Media" style="color:var(--accent-primary);"><i data-lucide="paperclip"></i></a>
                                        <% } %>
                                        <a href="/view/<%= concept._id %>" target="_blank" class="btn-icon" title="View"><i data-lucide="eye"></i></a>
                                        <a href="/concept/<%= concept._id %>" class="btn-icon" title="Manage"><i data-lucide="settings"></i></a>
                                    </div>
                                </div>
                                <% if (hasChildren) { %>
                                    <div class="tree-children" id="children-<%= concept._id %>">
                                        <div class="tree-list" style="margin-top:4px;">
                                            <% children.forEach(child => { renderNode(child, allInSubject, depth + 1); }) %>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
<%
    }
    const pool = subjects[subject];
    pool.filter(c => !c.parentId).forEach(c => renderNode(c, pool, 0));
%>
                    </div>
                </section>
            <% } %>
        <% } %>
    </main>

    <footer class="site-footer">
        <p>&copy; 2026 Concept Vault. Designed with &hearts; for learning.</p>
    </footer>

    <!-- Auth Modal Popup -->
    <div id="authModal" class="modal-overlay" style="display: none;">
        <div class="auth-modal-card">
            <div class="modal-close" onclick="closeAuthModal()"><i data-lucide="x"></i></div>
            <div class="modal-icon"><i data-lucide="shield-lock"></i></div>
            <h3>Secured Access</h3>
            <p>Enter token code to continue</p>
            <div id="modalError" class="modal-error" style="display: none;"></div>
            <input type="password" id="tokenInput" placeholder="Token Code" onkeyup="if(event.key==='Enter') verifyToken()">
            <button onclick="verifyToken()" id="verifyBtn" class="btn btn-primary" style="width:100%; margin-top:1rem;">Verify & Open</button>
        </div>
    </div>

    <style>
        .modal-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);
            display: flex; align-items: center; justify-content: center; z-index: 2000;
        }
        .auth-modal-card {
            background: #161622; padding: 2.5rem; border-radius: 20px; width: 90%; max-width: 360px;
            border: 1px solid rgba(255,255,255,0.1); text-align: center; position: relative;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .modal-close { position: absolute; top: 1rem; right: 1rem; cursor: pointer; color: #64748b; }
        .modal-icon { width: 50px; height: 50px; background: rgba(99,102,241,0.1); color: #6366f1; 
                      border-radius: 12px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
        .modal-error { background: rgba(239,68,68,0.1); color: #ef4444; padding: 0.5rem; border-radius: 8px; font-size: 0.8rem; margin-bottom: 1rem; }
        #tokenInput { width: 100%; background: #0f172a; border: 1px solid rgba(255,255,255,0.1); 
                      padding: 0.75rem; border-radius: 10px; color: white; box-sizing: border-box; }
        #tokenInput:focus { outline: none; border-color: #6366f1; }
    </style>

    <script>
        const isAuthenticated = <%= isAuthenticated %>;
        let pendingUrl = null;

        document.addEventListener('click', (e) => {
            const link = e.target.closest('a');
            if (!link || isAuthenticated) return;

            const href = link.getAttribute('href');
            if (href === '/upload' || href.startsWith('/concept/')) {
                // If it's not a viewer link (viewer is public)
                if (!href.includes('/media/viewer') && !href.includes('/view/')) {
                    e.preventDefault();
                    pendingUrl = href;
                    showAuthModal();
                }
            }
        });

        function showAuthModal() {
            document.getElementById('authModal').style.display = 'flex';
            document.getElementById('tokenInput').focus();
        }

        function closeAuthModal() {
            document.getElementById('authModal').style.display = 'none';
            document.getElementById('modalError').style.display = 'none';
        }

        async function verifyToken() {
            const token = document.getElementById('tokenInput').value;
            const btn = document.getElementById('verifyBtn');
            const error = document.getElementById('modalError');

            btn.disabled = true;
            btn.innerText = 'Verifying...';

            try {
                const res = await fetch('/auth/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tokenCode: token })
                });
                const data = await res.json();

                if (data.success) {
                    window.location.href = pendingUrl || '/';
                } else {
                    error.innerText = data.error;
                    error.style.display = 'block';
                    btn.disabled = false;
                    btn.innerText = 'Verify & Open';
                }
            } catch (err) {
                console.error(err);
                btn.disabled = false;
                btn.innerText = 'Verify & Open';
            }
        }

        function toggleNode(btn, id) {
            const children = document.getElementById('children-' + id);
            children.classList.toggle('collapsed');
            btn.classList.toggle('open');
        }

        function toggleMenu() {
            document.getElementById('navLinks').classList.toggle('active');
            document.getElementById('navOverlay').classList.toggle('active');
        }

        function filterBySubject(subject) {
            document.querySelectorAll('.subject-section').forEach(s => {
                s.style.display = (subject === 'all' || s.dataset.subject === subject) ? '' : 'none';
            });
        }

        lucide.createIcons();
    </script>
</body>
</html>
