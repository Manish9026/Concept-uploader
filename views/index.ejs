<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="nav-links">
            <div class="controls-bar" style="margin-bottom: 0; display: flex; gap: 0.5rem;">
                <select id="subject-filter" class="sort-select" onchange="filterBySubject(this.value)">
                    <option value="all">All Subjects</option>
                    <% Object.keys(subjects).forEach(s => { %>
                        <option value="<%= s %>"><%= s %></option>
                    <% }) %>
                </select>
                <select id="sort" class="sort-select" onchange="window.location.href='/?sort='+this.value">
                    <option value="order-asc" <%= sortBy === 'order-asc' ? 'selected' : '' %>>Sort Order</option>
                    <option value="date-desc" <%= sortBy === 'date-desc' ? 'selected' : '' %>>Latest First</option>
                    <option value="title-asc" <%= sortBy === 'title-asc' ? 'selected' : '' %>>Title A-Z</option>
                </select>
            </div>
            <a href="/upload" class="btn btn-primary nav-btn">New Concept +</a>
        </div>
    </nav>

    <main class="container">
        <% if (Object.keys(subjects).length === 0) { %>
            <div class="empty-state animate-fade-in">
                <h2>No concepts found yet</h2>
                <p>Start by uploading your first HTML concept file.</p>
                <br>
                <a href="/upload" class="btn btn-outline">Go to Upload</a>
            </div>
        <% } else { %>
            <% for (let subject in subjects) { %>
                <section class="subject-section animate-fade-in" id="section-<%= subject.replace(/\s+/g, '-').toLowerCase() %>" data-subject="<%= subject %>">
                    <div class="subject-header">
                        <h2 class="subject-title"><%= subject %></h2>
                    </div>
                    
                    <div class="concept-list">
                        <% 
                            // Filter for top-level concepts (no parent or parent not in this subject)
                            const topLevel = subjects[subject].filter(c => !c.parentId);
                            
                            function renderConcept(concept, allInSubject) {
                                const children = allInSubject.filter(c => c.parentId == concept.id);
                        %>
                            <div class="concept-group">
                                <div class="concept-item">
                                    <div class="concept-info">
                                        <h3><%= concept.title %></h3>
                                        <div class="concept-meta">
                                            <span>📅 <%= new Date(concept.uploadDate).toLocaleDateString() %></span>
                                            <% if (concept.sortOrder) { %>
                                                <span>🔢 Order: <%= concept.sortOrder %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="concept-actions">
                                        <a href="/uploads/<%= concept.filename %>" class="btn btn-outline" style="padding: 0.5rem 1rem;" target="_blank">View</a>
                                        <a href="/concept/<%= concept.id %>" class="btn btn-outline" style="padding: 0.5rem 1rem;">Manage ⚙️</a>
                                    </div>
                                </div>
                                
                                <% if (children.length > 0) { %>
                                    <div class="nested-wrapper">
                                        <% children.forEach(child => { %>
                                            <% renderConcept(child, allInSubject) %>
                                        <% }) %>
                                    </div>
                                <% } %>
                            </div>
                        <% 
                            }
                            topLevel.forEach(concept => renderConcept(concept, subjects[subject]));
                        %>
                    </div>
                </section>
            <% } %>
        <% } %>
    </main>

    <script>
        function filterBySubject(subject) {
            const sections = document.querySelectorAll('.subject-section');
            sections.forEach(section => {
                if (subject === 'all' || section.getAttribute('data-subject') === subject) {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });
        }
    </script>

    <footer class="container" style="text-align: center; padding: 4rem 0; color: var(--text-secondary); font-size: 0.9rem;">
        <p>&copy; 2026 Concept Vault. Designed with &hearts; for learning.</p>
    </footer>
</body>
</html>
