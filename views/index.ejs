<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="nav-logo">Concept Vault</a>
        <div class="menu-toggle" onclick="toggleMenu()">
            <span></span><span></span><span></span>
        </div>
        <div class="nav-links" id="navLinks">
            <div class="controls-bar" style="display:flex;gap:0.5rem;">
                <select id="subject-filter" class="sort-select" onchange="filterBySubject(this.value)">
                    <option value="all">All Subjects</option>
                    <% allSubjects.forEach(s => { %>
                        <option value="<%= s %>"><%= s %></option>
                    <% }) %>
                </select>
                <select id="sort" class="sort-select" onchange="window.location.href='/?sort='+this.value">
                    <option value="order-asc" <%= sortBy === 'order-asc' ? 'selected' : '' %>>Sort Order</option>
                    <option value="date-desc" <%= sortBy === 'date-desc' ? 'selected' : '' %>>Latest First</option>
                    <option value="title-asc" <%= sortBy === 'title-asc' ? 'selected' : '' %>>Title A-Z</option>
                </select>
            </div>
            <a href="/upload" class="btn btn-primary nav-btn">New Concept +</a>
        </div>
    </nav>

    <main class="container">
        <% if (Object.keys(subjects).length === 0) { %>
            <div class="empty-state animate-fade-in">
                <h2>No concepts yet</h2>
                <p>Upload your first HTML concept file to get started.</p>
                <br>
                <a href="/upload" class="btn btn-outline">Go to Upload</a>
            </div>
        <% } else { %>
            <% for (let subject in subjects) { %>
                <section class="subject-section animate-fade-in" data-subject="<%= subject %>">
                    <h2 class="subject-title"><%= subject %></h2>
                    <div class="tree-list">
<%
    function renderNode(concept, allInSubject, depth) {
        const children = allInSubject.filter(c => c.parentId && c.parentId.toString() === concept._id.toString());
        const hasChildren = children.length > 0;
%>
                        <div class="tree-row depth-<%= depth %>">
                            <div class="tree-rail"><div class="tree-dot"></div></div>
                            <div class="tree-arm"></div>
                            <div class="tree-card">
                                <div class="card-header">
                                    <% if (hasChildren) { %>
                                        <div class="toggle-btn open" onclick="toggleNode(this, '<%= concept._id %>')">
                                            <i data-lucide="chevron-right"></i>
                                        </div>
                                    <% } else { %>
                                        <div class="toggle-spacer"></div>
                                    <% } %>
                                    <div style="flex:1;min-width:0;">
                                        <div class="card-title"><%= concept.title %></div>
                                        <div class="card-meta">
                                            <span><i data-lucide="calendar"></i> <%= new Date(concept.uploadDate).toLocaleDateString() %></span>
                                            <% if (concept.sortOrder) { %>
                                                <span><i data-lucide="hash"></i> <%= concept.sortOrder %></span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div class="card-actions">
                                        <a href="/view/<%= concept._id %>" target="_blank" class="btn-icon" title="View"><i data-lucide="eye"></i></a>
                                        <a href="/concept/<%= concept._id %>" class="btn-icon" title="Manage"><i data-lucide="settings"></i></a>
                                    </div>
                                </div>
                                <% if (hasChildren) { %>
                                    <div class="tree-children" id="children-<%= concept._id %>">
                                        <div class="tree-list" style="margin-top:4px;">
                                            <% children.forEach(child => { renderNode(child, allInSubject, depth + 1); }) %>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
<%
    }
    const pool = subjects[subject];
    pool.filter(c => !c.parentId).forEach(c => renderNode(c, pool, 0));
%>
                    </div>
                </section>
            <% } %>
        <% } %>
    </main>

    <footer class="site-footer">
        <p>&copy; 2026 Concept Vault. Designed with &hearts; for learning.</p>
    </footer>

    <script>
        function toggleNode(btn, id) {
            const children = document.getElementById('children-' + id);
            children.classList.toggle('collapsed');
            btn.classList.toggle('open');
        }

        function toggleMenu() {
            document.getElementById('navLinks').classList.toggle('active');
        }

        function filterBySubject(subject) {
            document.querySelectorAll('.subject-section').forEach(s => {
                s.style.display = (subject === 'all' || s.dataset.subject === subject) ? '' : 'none';
            });
        }

        lucide.createIcons();
    </script>
</body>
</html>
